{
  "Routes": [
    {
      // Внутренний адрес сервиса Vault, куда Ocelot перенаправит запрос
      "DownstreamPathTemplate": "/api/Vault/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 7291
        }
      ],

      // Внешний адрес шлюз, который должен написать клиент
      "UpstreamPathTemplate": "/vault-service/{everything}",
      "UpstreamHttpMethod": [ "Get" ],

      // Ключ, наличие которого проверяется в сервисе, куда обращаемся (Vault_)
      // Если ключа нет - значит пользователь пытается обратиться к сервису напрямую, а не через гейтвей,
      // такой запрос не будет обработан
      "AddHeadersToRequest": {
        "OcelotGatewaySecretKey": "ocelotSecretKey"
      },
      "UpstreamHeaderTransform": {
        "OcelotGatewaySecretKey": "ocelotSecretKey"
      }
    }
  ]
}
